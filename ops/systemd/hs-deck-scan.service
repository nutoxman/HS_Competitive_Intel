[Unit]
Description=HS Tracker Pipeline Deck Scan
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=<CODEX_REPO>
Environment=HS_TRACKER_DB_PATH=<CODEX_REPO>/data/hs_tracker.db
ExecStart=<PYTHON_BIN> -m hs_tracker.jobs.run_deck_scan --deck-root data/pipeline_decks
User=<SERVICE_USER>
Group=<SERVICE_GROUP>
